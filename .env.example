# Copy to .env and fill in. You need ONE frontier vendor configured (Anthropic
# OR Gemini) plus an OSS backend.

# === Which frontier vendor to use: anthropic | gemini ===
# gemini = Google AI Studio free tier (no credit card). anthropic = Claude (paid).
FRONTIER_VENDOR=groq

# === Google Gemini (free tier) ===
# Get a free key at https://aistudio.google.com/apikey  (just a Google account)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# === Groq (free tier, open models) — used when FRONTIER_VENDOR=groq ===
# Get a free key at https://console.groq.com/keys (no credit card)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# === Anthropic (Claude) — only needed if FRONTIER_VENDOR=anthropic ===
ANTHROPIC_API_KEY=
FRONTIER_MODEL=claude-sonnet-4-6

# === Which backend the assistant uses by default: frontier | oss ===
BACKEND=frontier

# === Open-source backend ===
# OSS_BACKEND: transformers (local weights) | ollama | endpoint (OpenAI-compatible)
OSS_BACKEND=ollama
OSS_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434
OSS_ENDPOINT_URL=
OSS_ENDPOINT_KEY=
OSS_GPU_USD_PER_SEC=0.0

# === Generation ===
TEMPERATURE=0.7
MAX_TOKENS=640

# === Memory ===
MEMORY_MAX_TURNS=8
MEMORY_SUMMARIZE=true

# === Guardrails ===
GUARDRAILS_ENABLED=true
GUARDRAILS_LLM_CHECK=false

# === Tools ===
TOOLS_ENABLED=true

# === Observability ===
LOG_DIR=logs
